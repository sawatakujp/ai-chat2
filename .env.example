# AI API Keys
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Database (MongoDB)
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Google Cloud (GCS + Vertex AI Gemini)
GCS_BUCKET_NAME=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
# ローカル開発: gcloud auth application-default login 後は不要
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Cloud Run: Secret Manager 経由で JSON キーを文字列として設定
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
